# Notion
NOTION_API_KEY=
NOTION_DATABASE_ID=

# 캐시 수동 무효화 — /api/revalidate?secret=... 로 호출
REVALIDATE_SECRET=

# 배포 URL — OG 메타데이터 base URL (로컬: http://localhost:3000)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Google Analytics (운영 환경에서만 설정, 로컬은 비워두면 비활성화)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
